{
  "name": "@workspace/chess-research",
  "version": "0.1.0",
  "description": "Browser automation research framework for authorized chess testing environments",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./platforms": "./src/platforms/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "run:cli": "tsx src/cli/run.ts",
    "run:demo": "tsx src/cli/run.ts --mode demo",
    "run:replay": "tsx src/cli/run.ts --mode replay"
  },
  "dependencies": {
    "chess.js": "^1.3.0",
    "playwright": "^1.52.0",
    "stockfish": "^16.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.3"
  }
}
